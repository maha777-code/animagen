# Animagen environment variables

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001

# API (Fastify)
PORT=3001
HOST=0.0.0.0
REDIS_URL=redis://localhost:6379
INFERENCE_URL=http://localhost:8000
CACHE_TTL_SEC=86400
PARSER_CONFIDENCE_THRESHOLD=0.35
CORS_ORIGIN=http://localhost:3000

# Inference worker (Python)
INFERENCE_PORT=8000
VLLM_ENABLED=0
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_BASE_URL=http://localhost:8080/v1
VLLM_API_KEY=EMPTY
# LTX-2 cinematic worker (Animagen Pro Tier 3)
LTX_WORKER_URL=http://localhost:8010
LTX_PORT=8010
LTX_ENABLED=0
LTX_MODEL=Lightricks/LTX-2
LTX_OUTPUT_DIR=./outputs
LTX_STEPS=40
LTX_CFG=4.0
