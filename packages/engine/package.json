    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@animagen/scene-schema": "workspace:*",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/three": "^0.169.0",
    "vitest": "^2.1.2"
  }
}
