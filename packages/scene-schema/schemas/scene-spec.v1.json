{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://animagen.dev/schemas/scene-spec/v1.json",
  "title": "SceneSpec",
  "description": "Procedural 3D scene specification for Animagen",
  "type": "object",
  "required": ["version", "seed", "prompt", "subjects", "environment", "lighting", "animations", "camera", "effects"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "seed": { "type": "integer", "minimum": 0 },
    "prompt": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "subjects": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "dragon", "bird", "fish", "car", "robot", "human", "tree", "planet",
              "spaceship", "butterfly", "whale", "horse", "cat", "dog", "snake",
              "cube", "sphere", "flower", "house", "boat", "airplane", "rocket",
              "cloud", "mountain", "crystal", "unknown"
            ]
          },
          "color": { "type": "string" },
          "scale": { "type": "number", "exclusiveMinimum": 0, "maximum": 100 },
          "count": { "type": "integer", "exclusiveMinimum": 0, "maximum": 50 },
          "name": { "type": "string" }
        }
      }
    },
    "environment": {
      "type": "string",
      "enum": ["ocean", "forest", "desert", "space", "city", "mountains", "abstract", "meadow", "underwater", "volcano", "arctic", "cave", "sky", "beach", "jungle"]
    },
    "lighting": {
      "type": "object",
      "required": ["timeOfDay", "mood"],
      "additionalProperties": false,
      "properties": {
        "timeOfDay": { "type": "string", "enum": ["dawn", "morning", "noon", "afternoon", "sunset", "dusk", "night", "midnight"] },
        "mood": { "type": "string", "enum": ["calm", "dramatic", "mysterious", "cheerful", "dark", "epic", "peaceful", "stormy", "romantic", "eerie"] },
        "intensity": { "type": "number", "minimum": 0, "maximum": 2 }
      }
    },
    "animations": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "required": ["target", "motion", "speed"],
        "additionalProperties": false,
        "properties": {
          "target": { "type": "string" },
          "motion": { "type": "string", "enum": ["fly", "orbit", "walk", "swim", "bounce", "spin", "float", "idle", "run", "dive", "hover", "patrol", "wave", "pulse", "grow"] },
          "path": { "type": "string", "enum": ["circle", "figure8", "line", "sine", "spiral", "random", "spline"] },
          "speed": { "type": "number", "minimum": 0.1, "maximum": 10 },
          "loop": { "type": "boolean" },
          "duration": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    },
    "camera": {
      "type": "object",
      "required": ["movement", "duration"],
      "additionalProperties": false,
      "properties": {
        "movement": { "type": "string", "enum": ["orbit", "follow", "flythrough", "static"] },
        "duration": { "type": "number", "exclusiveMinimum": 0, "maximum": 300 },
        "target": { "type": "string" },
        "distance": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number" }
      }
    },
    "effects": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string",
        "enum": ["rain", "snow", "fog", "fire", "sparkles", "storm", "lightning", "bubbles", "dust", "leaves"]
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string", "enum": ["parser", "llm", "fallback"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "normalizedPrompt": { "type": "string" },
        "generatedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
